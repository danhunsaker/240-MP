{
  "id": "com.240mp.nfc_reader",
  "name": "NFC Reader",
  "icon": "assets/images/logo.svg",
  "entry_point_qml": "views/Root.qml",
  "settings": [
    {
      "key": "enabled",
      "label": "Enabled",
      "type": "toggle",
      "default": "OFF"
    },
    {
      "key": "tags_directory",
      "label": "Tags Directory",
      "type": "directory_browser",
      "default": ""
    },
    {
      "key": "resume_playback",
      "label": "Resume Playback",
      "type": "list_single",
      "options_source": "dynamic",
      "options_slot": "get_resume_playback_options",
      "default": "ask"
    },
    {
      "key": "playback_resolution",
      "label": "YouTube Video Resolution",
      "type": "list_single",
      "options": [
        "480p",
        "720p",
        "1080p"
      ],
      "default": "480p"
    },
    {
      "key": "auto_subtitles",
      "label": "Auto Show Subtitles",
      "type": "list_single",
      "options_source": "dynamic",
      "options_slot": "get_auto_subtitles_options",
      "default": "forced",
      "description": "Choose to automatically show subtitles when a video starts.\n[FORCED ONLY] displays for foreign dialogue only."
    },
    {
      "key": "sub_lang",
      "label": "Subtitle Language",
      "type": "list_single",
      "options_source": "dynamic",
      "options_slot": "get_subtitle_languages",
      "default": "-",
      "description": "Select which language to automatically load subtitles for.\n[Any] is the same as 'no preference'."
    }
  ]
}